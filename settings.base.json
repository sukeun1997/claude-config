{
  "env": {
    "enable_tool_search": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(credentials.json)",
      "Bash(cat .env*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(cat credentials.json)",
      "Bash(cat .credentials.json)"
    ],
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "WebFetch(*)",
      "WebSearch",
      "Skill(*)",
      "mcp__chrome-devtools__*",
      "mcp__claude_ai_Context7__*",
      "mcp__plugin_github_github__*",
      "mcp__cli-proxy-api__ask_gemini",
      "mcp__cli-proxy-api__ask_codex",
      "mcp__cli-proxy-api__list_proxy_models",
      "mcp__ide__getDiagnostics"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/memory-session-start.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/memory-promote-analyzer.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/memory-post-tool.py\"",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/prisma-auto-generate.mjs\""
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/tool-tracker.sh\"",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/governance-guard.sh\"",
            "if": "Write(*) || Edit(*)",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/skill-usage-tracker.sh\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo '새 기능 구현 작업이면 /feature 스킬을 사용하세요. brainstorming → plan → execution 2-gate 흐름이 적용됩니다. 리팩토링/마이그레이션 등 기능 구현이 아닌 작업이면 그대로 Plan 모드를 진행하세요.'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/memory-precompact-path.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/memory-stop-guard.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/memory-active-context.sh\" update 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/memory-post-tool.py\" flush 2>/dev/null || true",
            "timeout": 5,
            "async": true
          },
          {
            "type": "command",
            "command": "SID=$(cat \"$HOME/.claude/memory/sessions/.current-session-id\" 2>/dev/null || echo unknown); STS=$(cat \"$HOME/.claude/memory/sessions/.last-session-ts\" 2>/dev/null || echo 0); \"$HOME/.claude/hooks/memory-session-end.sh\" \"$SID\" \"$STS\"",
            "timeout": 15,
            "async": true
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/observer-runner.sh\"",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/settings-integrity-guard.sh\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/pre-clear-handoff.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); runtime=$(command -v bun 2>/dev/null || command -v node 2>/dev/null); exec \"$runtime\" \"${plugin_dir}dist/index.js\"'"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "github@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true,
    "swift-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "telegram@claude-plugins-official": true
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
